{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "STM32: Configure (Debug)",
      "type": "shell",
      "command": "cmake --preset stm32-debug",
      "options": {
        "cwd": "${workspaceFolder}/Software/STM32F103RBTx"
      }
    },
    {
      "label": "STM32: Build (Debug)",
      "type": "shell",
      "command": "cmake --build --preset build-stm32-debug",
      "options": {
        "cwd": "${workspaceFolder}/Software/STM32F103RBTx"
      },
      "dependsOn": [
        "STM32: Configure (Debug)"
      ],
      "group": "build",
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "STM32: Flash (Debug)",
      "type": "shell",
      "command": "cmake --build --preset build-stm32-debug --target flash",
      "options": {
        "cwd": "${workspaceFolder}/Software/STM32F103RBTx"
      },
      "dependsOn": [
        "STM32: Build (Debug)"
      ]
    },
    {
      "label": "STM32: Configure (Release)",
      "type": "shell",
      "command": "cmake --preset stm32-release --fresh",
      "options": {
        "cwd": "${workspaceFolder}/Software/STM32F103RBTx"
      }
    },
    {
      "label": "STM32: Build (Release)",
      "type": "shell",
      "command": "cmake --build --preset build-stm32-release",
      "options": {
        "cwd": "${workspaceFolder}/Software/STM32F103RBTx"
      },
      "dependsOn": [
        "STM32: Configure (Release)"
      ],
      "group": "build",
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "STM32: Flash (Release)",
      "type": "shell",
      "command": "cmake --build --preset build-stm32-release --target flash",
      "options": {
        "cwd": "${workspaceFolder}/Software/STM32F103RBTx"
      },
      "dependsOn": [
        "STM32: Build (Release)"
      ],
      "problemMatcher": []
    }
  ]
}